#           Copy this file to .env and put your real key there.
OPENAI_API_KEY=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

# ── Per-task model strategy ───────────────────────────────────────────────────
# Each task uses an independently configurable model.
# Change any value here — zero code changes required in business logic.
#
# CV_PARSE_MODEL   → gpt-4.1-mini  (fast & cheap — high-volume extraction)
# ANALYSIS_MODEL   → gpt-4.1       (better reasoning — semantic scoring)
# REPORT_MODEL     → gpt-4.1       (highest quality — comparative narrative)
#
# Future: swap to gpt-5 or a local model by changing a single line below.
OPENAI_CV_PARSE_MODEL=gpt-4.1-mini
OPENAI_ANALYSIS_MODEL=gpt-4.1
OPENAI_REPORT_MODEL=gpt-4.1
