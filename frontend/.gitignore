# Frontend-specific ignores
# (Most are covered by the root .gitignore, but these are local backups)

node_modules/
dist/
dist-ssr/
*.local

# Environment files (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDEs
.vscode/
.idea/
*.sw?
.DS_Store
